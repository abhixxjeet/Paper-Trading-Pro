{
  "rewrites": [
    { "source": "/api/stocks/quote", "destination": "/api/stocks/quote" },
    { "source": "/api/stocks/quotes", "destination": "/api/stocks/quotes" },
    { "source": "/api/stocks/history", "destination": "/api/stocks/history" },
    { "source": "/api/stocks/search", "destination": "/api/stocks/search" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=15, stale-while-revalidate=30" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}
